DOCUSIGN_API_ACCOUNT_ID=your_account_id
DOCUSIGN_INTEGRATION_KEY=your_integration_key

# Prey API
PREY_API_KEY=your_prey_api_key

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Frontend URL
FRONTEND_URL=http://localhost:3000
