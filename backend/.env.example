NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/drmobicare
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Shippo API
SHIPPO_API_KEY=your_shippo_api_key

# DocuSign API
DOCUSIGN_CLIENT_ID=your_docusign_client_id
